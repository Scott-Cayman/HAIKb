[Unit]
Description=HAIKB Backend API Service
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/HAIKB/enterprise-knowledge-drive/backend
Environment="PYTHONIOENCODING=utf-8"
Environment="LC_ALL=en_US.UTF-8"
Environment="LANG=en_US.UTF-8"
ExecStart=/home/HAIKB/enterprise-knowledge-drive/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 9090
Restart=always
RestartSec=5
StandardOutput=append:/home/HAIKB/enterprise-knowledge-drive/logs/backend/stdout.log
StandardError=append:/home/HAIKB/enterprise-knowledge-drive/logs/backend/stderr.log

[Install]
WantedBy=multi-user.target
